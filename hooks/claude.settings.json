{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -m 1 -G --data-urlencode \"source=claude-code\" --data-urlencode \"session_id=$CLAUDE_SESSION_ID\" --data-urlencode \"cwd=$PWD\" --data-urlencode \"event=start\" http://127.0.0.1:57017/hook 2>/dev/null || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -m 1 -G --data-urlencode \"source=claude-code\" --data-urlencode \"session_id=$CLAUDE_SESSION_ID\" --data-urlencode \"cwd=$PWD\" --data-urlencode \"event=thinking\" http://127.0.0.1:57017/hook 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -m 1 -G --data-urlencode \"source=claude-code\" --data-urlencode \"session_id=$CLAUDE_SESSION_ID\" --data-urlencode \"cwd=$PWD\" --data-urlencode \"event=tool_use\" --data-urlencode \"tool_name=$CLAUDE_TOOL_NAME\" http://127.0.0.1:57017/hook 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -m 1 -G --data-urlencode \"source=claude-code\" --data-urlencode \"session_id=$CLAUDE_SESSION_ID\" --data-urlencode \"cwd=$PWD\" --data-urlencode \"event=thinking\" http://127.0.0.1:57017/hook 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -m 1 -G --data-urlencode \"source=claude-code\" --data-urlencode \"session_id=$CLAUDE_SESSION_ID\" --data-urlencode \"cwd=$PWD\" --data-urlencode \"event=stop\" http://127.0.0.1:57017/hook 2>/dev/null || true"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -m 1 -G --data-urlencode \"source=claude-code\" --data-urlencode \"session_id=$CLAUDE_SESSION_ID\" --data-urlencode \"cwd=$PWD\" --data-urlencode \"event=exit\" http://127.0.0.1:57017/hook 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}