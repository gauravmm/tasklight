{
  "_comment": "Install hooks/tasklight-claude-hook.sh to ~/.claude/hooks/ before merging.",
  "hooks": {
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "bash ~/.claude/hooks/tasklight-claude-hook.sh" } ] }
    ],
    "PreToolUse": [
      { "matcher": "*", "hooks": [ { "type": "command", "command": "bash ~/.claude/hooks/tasklight-claude-hook.sh" } ] }
    ],
    "PostToolUse": [
      { "matcher": "*", "hooks": [ { "type": "command", "command": "bash ~/.claude/hooks/tasklight-claude-hook.sh" } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "bash ~/.claude/hooks/tasklight-claude-hook.sh" } ] }
    ],
    "SessionEnd": [
      { "hooks": [ { "type": "command", "command": "bash ~/.claude/hooks/tasklight-claude-hook.sh" } ] }
    ],
    "PermissionRequest": [
      { "hooks": [ { "type": "command", "command": "bash ~/.claude/hooks/tasklight-claude-hook.sh" } ] }
    ]
  }
}
